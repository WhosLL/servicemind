# Copy to .env.local and fill in for local dev. Never commit real values.
# For local dev, pull current Vercel prod values with: `vercel env pull .env.local`

# --- Supabase ---
# URL + anon key are public by design (NEXT_PUBLIC_ ships them to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Full DB admin. Server-side only. Bypasses RLS. Never log, never ship to client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Twilio (SMS + voice) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=
